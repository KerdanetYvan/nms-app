# =============================================================================
# Variables d'environnement — Application Doo (Expo / React Native)
# =============================================================================
#
# UTILISATION :
#   1. Copie ce fichier et renomme-le ".env" à la racine de /frontend
#   2. Remplis chaque valeur avec tes vraies credentials
#   3. Ne commite JAMAIS le fichier .env (il est dans .gitignore)
#
# OÙ TROUVER CES VALEURS :
#   Supabase Dashboard → ton projet → Settings → API
#
# CONVENTION EXPO :
#   Les variables préfixées EXPO_PUBLIC_ sont exposées côté client (bundle JS).
#   Ne mets jamais de secrets serveur (service_role key, clés privées) ici.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------

# URL de ton projet Supabase
# Format : https://<project-ref>.supabase.co
# Onglet : Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé publique "anon" (safe à exposer côté client — protégée par les RLS policies)
# Onglet : Settings → API → Project API Keys → anon / public
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
